# Copy this file to .env and fill in your values

# Django
SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# OpenRouter API Key (get yours at https://openrouter.ai)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# LLM Model (choose a free model from https://openrouter.ai/collections/free-models)
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# Vector store path (inside container)
VECTOR_STORE_PATH=/app/vector_store

# Embedding model (local HuggingFace model, no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
